@prefix synthesist: <https://nomograph.org/synthesist/> .
@prefix nomograph: <https://nomograph.org/v3/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

#
# Synthesist (synthesist:) module SHACL shapes.
#
# Documentation artifact. NOT a runtime gate. Synthesist's imperative
# validators in src/schema/*.rs remain authoritative; SHACL ships
# alongside the binary as a declarative description for LLM and
# external-tool consumption.
#
# Source of truth for each enum (sh:in lists): the Rust constants
# in src/schema/<type>.rs. This file is generated by `emit-shacl`;
# do NOT edit by hand. Run `make shacl` to regenerate.
#
# Every shape extends the universal envelope by including the four
# substrate-universal predicates: @id (sh:targetClass binds this),
# rdf:type, prov:generatedAtTime, prov:wasAttributedTo. The base
# shape in nomograph-claim's ontology/base.shacl.ttl covers those
# constraints; each shape here adds per-type constraints.
#

#
# Tree -- top-level project domain.
#

synthesist:TreeShape a sh:NodeShape ;
    sh:targetClass synthesist:Tree ;
    rdfs:label "Tree shape"@en ;
    sh:property [
        sh:path synthesist:name ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path synthesist:description ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] .

#
# Spec -- unit of work; goal + constraints + decisions.
#

synthesist:SpecShape a sh:NodeShape ;
    sh:targetClass synthesist:Spec ;
    rdfs:label "Spec shape"@en ;
    sh:property [
        sh:path synthesist:tree ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path synthesist:id ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path synthesist:goal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path synthesist:status ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:in ( "draft" "active" "done" "superseded" ) ;
    ] ;
    sh:property [
        sh:path synthesist:constraints ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path synthesist:decisions ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path synthesist:topics ;
        sh:minCount 1 ;
        sh:nodeKind sh:Literal ;
    ] ;
    sh:property [
        sh:path synthesist:agree_snapshot ;
        sh:nodeKind sh:IRI ;
    ] .

#
# Task -- atomic work item within a spec.
#

synthesist:TaskShape a sh:NodeShape ;
    sh:targetClass synthesist:Task ;
    rdfs:label "Task shape"@en ;
    sh:property [
        sh:path synthesist:tree ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path synthesist:spec ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path synthesist:id ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path synthesist:summary ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path synthesist:status ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:in ( "pending" "in_progress" "done" "blocked" "waiting" "cancelled" ) ;
    ] ;
    sh:property [
        sh:path synthesist:gate ;
        sh:maxCount 1 ;
        sh:in ( "human" ) ;
    ] ;
    sh:property [
        sh:path synthesist:description ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path synthesist:owner ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path synthesist:depends_on ;
        sh:nodeKind sh:Literal ;
    ] ;
    sh:property [
        sh:path synthesist:files ;
        sh:nodeKind sh:Literal ;
    ] .

#
# Discovery -- append-only institutional memory per spec.
#

synthesist:DiscoveryShape a sh:NodeShape ;
    sh:targetClass synthesist:Discovery ;
    rdfs:label "Discovery shape"@en ;
    sh:property [
        sh:path synthesist:tree ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path synthesist:spec ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path synthesist:id ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path synthesist:date ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path synthesist:finding ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path synthesist:author ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path synthesist:impact ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path synthesist:action ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] .

#
# Session -- isolated work copy with metadata.
#

synthesist:SessionShape a sh:NodeShape ;
    sh:targetClass synthesist:Session ;
    rdfs:label "Session shape"@en ;
    sh:property [
        sh:path synthesist:id ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path synthesist:tree ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path synthesist:spec ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path synthesist:summary ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] .

#
# Phase -- per-session workflow state.
#

synthesist:PhaseShape a sh:NodeShape ;
    sh:targetClass synthesist:Phase ;
    rdfs:label "Phase shape"@en ;
    sh:property [
        sh:path synthesist:session_id ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path synthesist:name ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:in ( "orient" "plan" "agree" "execute" "reflect" "replan" "report" ) ;
    ] .

#
# Campaign -- cross-spec coordination.
#

synthesist:CampaignShape a sh:NodeShape ;
    sh:targetClass synthesist:Campaign ;
    rdfs:label "Campaign shape"@en ;
    sh:property [
        sh:path synthesist:tree ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path synthesist:spec ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path synthesist:kind ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:in ( "active" "backlog" ) ;
    ] ;
    sh:property [
        sh:path synthesist:summary ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path synthesist:title ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path synthesist:blocked_by ;
        sh:nodeKind sh:Literal ;
    ] .

#
# Outcome -- what happened to a spec (distinct from Spec status).
#

synthesist:OutcomeShape a sh:NodeShape ;
    sh:targetClass synthesist:Outcome ;
    rdfs:label "Outcome shape"@en ;
    sh:property [
        sh:path synthesist:tree ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path synthesist:spec ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path synthesist:status ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:in ( "completed" "abandoned" "deferred" "superseded_by" ) ;
    ] ;
    sh:property [
        sh:path synthesist:note ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path synthesist:linked_spec ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path synthesist:date ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] .
