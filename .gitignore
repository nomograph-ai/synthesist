.DS_Store
*.log

# Fixtures seeded by jig agent-shape runs. Regenerated deterministically
# by scripts/agent-shape-fixture.sh; the output has no value tracked.
fixtures/

# Rust build artifacts (root + nested tool crates)
/target
tools/*/target/

# Binary (release builds)
/synthesist
dist/

# v1 data directory. Kept ignored in v2 so leftover databases and
# migrator-written backups (`.synth/main.db.v1-backup-*`) don't get
# accidentally committed post-migration.
.synth/

# Claim store cache files. Tracked under claims/: genesis.amc,
# changes/<hash>.amc, config.toml. Everything else is derived.
claims/view.sqlite
claims/view.sqlite-journal
claims/view.sqlite-wal
claims/view.sqlite-shm
claims/view.heads
claims/snapshot.amc
claims/.lock

# .agent/skills compat symlink: regenerated by `make agent-skills-symlink`.
# Intentionally untracked so external tools that rewrite symlinks (e.g.
# certain rune sync versions) cannot commit an absolute target. The
# symlink is the relative form `.agent/skills -> ../.claude/skills`.
.agent/skills

# `.claude/` is local-only: rune subscriptions, lockfile, and synced skill
# content are all per-developer state. Run `rune setup` then `rune sync` on a
# fresh clone to materialize.
.claude/

# `AGENTS.md` is generated by `rune sync` based on the project's skill
# subscriptions, same drift class as `.claude/skills/`. Per-developer
# state; not part of the repo's public contract.
AGENTS.md
